# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+psycopg://user:pass@127.0.0.1:5433/events"

# Set at least one LLM provider key. Anthropic is preferred; OpenAI is the fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Recommended ───────────────────────────────────────────────────────────────
# Protects all API endpoints. Generate with: openssl rand -hex 32
# Leave blank to disable auth (dev only).
API_KEY=

# ── External Kafka / Redpanda ─────────────────────────────────────────────────
# Optional default broker for all tenants. Leave blank and configure per tenant.
# Broker/auth details are usually configured per tenant in the Settings tab.
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_CONSUMER_GROUP_PREFIX=ai-events
# Required before saving tenant SASL passwords.
# Generate with:
# python -c "from app.security.encryption import generate_encryption_key; print(generate_encryption_key())"
KAFKA_CREDENTIAL_ENCRYPTION_KEY=

# ── MCP server (Claude Code integration) ─────────────────────────────────────
MCP_DEFAULT_TENANT_ID=
MCP_DATABASE_URL=postgresql+psycopg://mcp_reader:changeme@127.0.0.1:5433/events

# ── Optional: Slack alerts ────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Optional: SMS / WhatsApp alerts (Twilio) ─────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Optional: ngrok (needed for Slack/Twilio webhooks) ───────────────────────
# Start with: docker compose --profile ngrok up
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# ── Demo data ─────────────────────────────────────────────────────────────────
INCLUDE_DEMO_TENANT=true
# Leave false unless you intentionally want the seed job to publish demo messages
# to the global KAFKA_BOOTSTRAP_SERVERS broker.
PUBLISH_DEMO_KAFKA_EVENTS=false
